<Window x:Class="ScreenshotTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Screenshot Tool"
        WindowStyle="None" AllowsTransparency="True" Background="#01000000"
        Topmost="True" ShowInTaskbar="False" Focusable="True">
    
    <Window.Resources>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ColorDot" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" Stroke="#BBBBBB" StrokeThickness="1" Name="Circle"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Stroke" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Name="MainGrid" MouseDown="Window_MouseDown" MouseMove="Window_MouseMove" MouseUp="Window_MouseUp">
        <Image Name="BackgroundCapture" Stretch="Fill"/>
        <Path Name="DimmingPath" Fill="#AA000000" Stroke="White" StrokeThickness="1" StrokeDashArray="4 4">
            <Path.Data>
                <GeometryGroup FillRule="EvenOdd">
                    <RectangleGeometry x:Name="FullAreaGeometry"/>
                    <RectangleGeometry x:Name="SelectionGeometry"/>
                </GeometryGroup>
            </Path.Data>
        </Path>

        <skia:SKElement Name="SkiaCanvas" PaintSurface="SkiaCanvas_PaintSurface" Visibility="Collapsed" IsHitTestVisible="False"/>
        
        <!-- Text layer: Simplfied to catch clicks via the Window -->
        <Canvas Name="TextEditCanvas" IsHitTestVisible="False" Background="Transparent"/>

        <Canvas Name="ToolbarCanvas" Visibility="Collapsed">
            <Border Name="ToolbarBorder" Background="White" CornerRadius="10" BorderBrush="#DDDDDD" BorderThickness="1" Padding="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ToolArrow" Style="{StaticResource ToolBtn}" Content="&#xE72A;" Click="Tool_Click" Tag="Arrow" ToolTip="Arrow Tool"/>
                    <Button x:Name="ToolRect" Style="{StaticResource ToolBtn}" Content="&#xEA3A;" Click="Tool_Click" Tag="Rectangle" ToolTip="Rectangle Tool"/>
                    <Button x:Name="ToolPen" Style="{StaticResource ToolBtn}" Content="&#xED63;" Click="Tool_Click" Tag="Freehand" ToolTip="Pen Tool"/>
                    
                    <!-- Blur Tool with Custom Icon (Dot Grid) -->
                    <Button x:Name="ToolBlur" Style="{StaticResource ToolBtn}" Click="Tool_Click" Tag="Blur" ToolTip="Blur Tool">
                        <Viewbox Width="20" Height="20">
                            <Path Fill="Black" Data="M0,0h4v4h-4V0z M8,0h4v4h-4V0z M16,0h4v4h-4V0z M0,8h4v4h-4V8z M8,8h4v4h-4V8z M16,8h4v4h-4V8z M0,16h4v4h-4V16z M8,16h4v4h-4V16z M16,16h4v4h-4V16z"/>
                        </Viewbox>
                    </Button>

                    <Button x:Name="ToolText" Style="{StaticResource ToolBtn}" Content="&#xE8D2;" Click="Tool_Click" Tag="Text" ToolTip="Text Tool"/>
                    
                    <Separator Margin="10,4" Background="#EEEEEE"/>

                    <StackPanel Orientation="Horizontal" Margin="5,0" VerticalAlignment="Center">
                        <Button x:Name="ColorRed" Style="{StaticResource ColorDot}" Background="Red" Click="Color_Click" Tag="Red"/>
                        <Button x:Name="ColorGreen" Style="{StaticResource ColorDot}" Background="Green" Click="Color_Click" Tag="Green"/>
                        <Button x:Name="ColorBlue" Style="{StaticResource ColorDot}" Background="Blue" Click="Color_Click" Tag="Blue"/>
                        <Button x:Name="ColorYellow" Style="{StaticResource ColorDot}" Background="Yellow" Click="Color_Click" Tag="Yellow"/>
                        <Button x:Name="ColorBlack" Style="{StaticResource ColorDot}" Background="Black" Click="Color_Click" Tag="Black"/>
                    </StackPanel>

                    <Separator Margin="10,4" Background="#EEEEEE"/>

                    <Button Style="{StaticResource ToolBtn}" Content="&#xE7A7;" Click="Undo_Click" ToolTip="Undo"/>
                    <Button Style="{StaticResource ToolBtn}" Content="&#xE8FB;" Click="Done_Click" Foreground="#2E7D32" FontSize="24" ToolTip="Done"/>
                    <Button Style="{StaticResource ToolBtn}" Content="&#xE711;" Click="Exit_Click" Foreground="#C62828" ToolTip="Cancel"/>
                </StackPanel>
            </Border>
        </Canvas>

        <Button Name="DebugTrigger" Content="DEBUG: Start Capture" VerticalAlignment="Top" HorizontalAlignment="Left" 
                Padding="10,5" Margin="20" Click="OnDebugTrigger_Click" Opacity="0.7" Background="LightYellow" Visibility="Visible" Focusable="False"/>
    </Grid>
</Window>
