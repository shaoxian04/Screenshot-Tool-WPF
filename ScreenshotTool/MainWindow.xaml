<Window x:Class="ScreenshotTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Screenshot Tool" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp">
    
    <Grid x:Name="RootGrid">
        <!-- 1. Background Capture Image -->
        <Image x:Name="BackgroundCapture" Stretch="Fill" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- 2. Dimming Layer with Cutout -->
        <Path x:Name="DimmingPath" Fill="#B0000000">
            <Path.Data>
                <CombinedGeometry GeometryCombineMode="Exclude">
                    <CombinedGeometry.Geometry1>
                        <RectangleGeometry x:Name="FullAreaGeometry" Rect="0,0,10000,5000"/>
                    </CombinedGeometry.Geometry1>
                    <CombinedGeometry.Geometry2>
                        <RectangleGeometry x:Name="SelectionGeometry" Rect="0,0,0,0"/>
                    </CombinedGeometry.Geometry2>
                </CombinedGeometry>
            </Path.Data>
        </Path>

        <!-- 3. High-Contrast Selection Glow -->
        <Canvas IsHitTestVisible="False">
            <Rectangle x:Name="SelectionFrame" Stroke="White" StrokeThickness="3" Visibility="Collapsed">
                <Rectangle.Effect>
                    <DropShadowEffect Color="Gold" BlurRadius="10" ShadowDepth="0" Opacity="1"/>
                </Rectangle.Effect>
            </Rectangle>
            <Rectangle x:Name="SelectionFrameInner" Stroke="Black" StrokeThickness="1" Margin="1" Visibility="Collapsed"/>
        </Canvas>

        <!-- 4. Skia Annotation Canvas -->
        <skia:SKElement x:Name="SkiaCanvas" Visibility="Collapsed" PaintSurface="SkiaCanvas_PaintSurface"/>

        <!-- 5. TOPMOST Layer for Text Input (Hollow background so clicks pass to Window) -->
        <Canvas x:Name="TextEditCanvas" Background="{x:Null}" Visibility="Collapsed" IsHitTestVisible="True"/>

        <!-- 6. Floating Toolbar Layer -->
        <Canvas x:Name="ToolbarCanvas" Visibility="Collapsed">
            <Border x:Name="ToolbarBorder" Background="#F3F3F3" CornerRadius="8" Padding="12,8" 
                    BorderBrush="#CCCCCC" BorderThickness="1" MinWidth="520" Height="50"
                    MouseLeftButtonDown="Toolbar_MouseLeftButtonDown"
                    MouseMove="Toolbar_MouseMove"
                    MouseLeftButtonUp="Toolbar_MouseLeftButtonUp">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="ToolArrow" Tag="Arrow" Click="Tool_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Arrow">
                        <Path Data="M13.1,3.3l8.6,8.1c0.4,0.4,0.4,1,0,1.4l-8.6,8.1c-0.4,0.4-1,0.4-1.4,0c-0.4-0.4-0.4-1,0-1.4l6.9-6.5H3c-0.6,0-1-0.4-1-1s0.4-1,1-1h15.6l-6.9-6.5c-0.4-0.4-0.4-1,0-1.4C12.1,2.9,12.7,2.9,13.1,3.3z" Fill="#333" Stretch="Uniform" Width="18"/>
                    </Button>
                    <Button x:Name="ToolRect" Tag="Rectangle" Click="Tool_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Rectangle">
                        <Rectangle Width="18" Height="14" Stroke="#333" StrokeThickness="2"/>
                    </Button>
                    <Button x:Name="ToolPen" Tag="Freehand" Click="Tool_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Pen">
                        <Path Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.88L3,17.25M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.13,5.08L18.88,8.14L20.71,7.04Z" Fill="#333" Stretch="Uniform" Width="18"/>
                    </Button>
                    <Button x:Name="ToolBlur" Tag="Blur" Click="Tool_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Blur">
                        <Grid Width="18" Height="18">
                            <Rectangle Fill="#AAA" Margin="0,0,9,9"/>
                            <Rectangle Fill="#666" Margin="9,0,0,9"/>
                            <Rectangle Fill="#666" Margin="0,9,9,0"/>
                            <Rectangle Fill="#AAA" Margin="9,9,0,0"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ToolText" Tag="Text" Click="Tool_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Text">
                        <TextBlock Text="T" Foreground="#333" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Separator Width="1" Background="#DDD" Margin="10,4"/>
                    <Button x:Name="ColorRed" Tag="Red" Click="Color_Click" Width="22" Height="22" Margin="4,0" Background="Red" BorderThickness="0"/>
                    <Button x:Name="ColorGreen" Tag="Green" Click="Color_Click" Width="22" Height="22" Margin="4,0" Background="Green" BorderThickness="0"/>
                    <Button x:Name="ColorBlue" Tag="Blue" Click="Color_Click" Width="22" Height="22" Margin="4,0" Background="Blue" BorderThickness="0"/>
                    <Button x:Name="ColorYellow" Tag="Yellow" Click="Color_Click" Width="22" Height="22" Margin="4,0" Background="Yellow" BorderThickness="0"/>
                    <Button x:Name="ColorBlack" Tag="Black" Click="Color_Click" Width="22" Height="22" Margin="4,0" Background="Black" BorderThickness="0"/>
                    <Separator Width="1" Background="#DDD" Margin="10,4"/>
                    <Button x:Name="BtnUndo" Click="Undo_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Undo">
                        <Path Data="M12.5,8C9.85,8 7.45,8.99 5.6,10.6L2,7V16H11L7.38,12.38C8.77,11.22 10.54,10.5 12.5,10.5C16.04,10.5 19.05,12.81 20.1,16L22.47,15.22C21.08,11.03 17.15,8 12.5,8Z" Fill="#333" Stretch="Uniform" Width="18"/>
                    </Button>
                    <Button x:Name="BtnDone" Click="Done_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Done">
                        <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" Fill="Green" Stretch="Uniform" Width="22"/>
                    </Button>
                    <Button x:Name="BtnExit" Click="Exit_Click" Width="36" Margin="4,0" Background="Transparent" BorderThickness="0" ToolTip="Cancel">
                        <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="Red" Stretch="Uniform" Width="18"/>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Debug Trigger -->
        <Button x:Name="DebugTrigger" Content="DEBUG: Start Capture" VerticalAlignment="Top" HorizontalAlignment="Left" Click="OnDebugTrigger_Click" Visibility="Collapsed"/>
    </Grid>
</Window>
